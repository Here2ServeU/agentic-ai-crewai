# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Agentic AI Systems Engineer · Video 4
# Transformed 2 Succeed (T2S) · Emmanuel Naweji
# https://www.emmanuelnaweji.com
#
# HOW TO USE THIS FILE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your keys below
#   3. Never commit .env to GitHub — it is already in .gitignore
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────
# REQUIRED — OpenAI
# Get your key at: https://platform.openai.com/api-keys
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# Model to use (default is gpt-4o — change only if needed)
OPENAI_MODEL_NAME=gpt-4o


# ─────────────────────────────────────────────
# OPTIONAL — Serper (Web Search Tool)
# Gives agents the ability to search the live web
# Free tier available at: https://serper.dev
# ─────────────────────────────────────────────
SERPER_API_KEY=your-serper-key-here


# ─────────────────────────────────────────────
# OPTIONAL — LangSmith (Observability & Tracing)
# Traces every agent step, token usage, and latency
# Sign up at: https://smith.langchain.com
# ─────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=t2s-agentic-ai-video4


# ─────────────────────────────────────────────
# OPTIONAL — Anthropic (Claude models via CrewAI)
# Use if you want to swap OpenAI for Claude
# Get your key at: https://console.anthropic.com
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here


# ─────────────────────────────────────────────
# OPTIONAL — Environment Tag
# Helps you distinguish local vs production logs
# Values: development | staging | production
# ─────────────────────────────────────────────
APP_ENV=development
